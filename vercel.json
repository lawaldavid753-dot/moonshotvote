{
  "functions": {
    "api/token.js": {
      "memory": 1024,
      "maxDuration": 10,
      "includeFiles": "index.html"
    },
    "api/og.js": {
      "memory": 256,
      "maxDuration": 10
    }
  },
  "rewrites": [
    { "source": "/([A-Za-z0-9]{20,})", "destination": "/api/token?ca=$1" }
  ]
}
